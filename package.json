{
  "name": "stocklens",
  "displayName": "StockLens",
  "description": "Comprehensive equity research and portfolio analysis with charts and multi-broker support",
  "version": "1.2.2",
  "publisher": "sanjaisakthivel",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "portfolio",
    "stocks",
    "equity",
    "research",
    "IndMoney",
    "trading",
    "charts"
  ],
  "icon": "media/icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "portfolioAnalyzer.openDashboard",
        "title": "StockLens: Open Dashboard",
        "icon": "$(graph)"
      },
      {
        "command": "portfolioAnalyzer.refreshData",
        "title": "StockLens: Refresh Data",
        "icon": "$(refresh)"
      },
      {
        "command": "portfolioAnalyzer.configureProvider",
        "title": "StockLens: Configure Broker",
        "icon": "$(gear)"
      },
      {
        "command": "portfolioAnalyzer.showScoringInfo",
        "title": "StockLens: Scoring Methodology",
        "icon": "$(info)"
      },
      {
        "command": "portfolioAnalyzer.searchStock",
        "title": "StockLens: Search & Analyze Stock",
        "icon": "$(search)"
      },
      {
        "command": "portfolioAnalyzer.refreshWatchlist",
        "title": "StockLens: Refresh Watchlist",
        "icon": "$(refresh)"
      },
      {
        "command": "portfolioAnalyzer.newWatchlist",
        "title": "StockLens: New Watchlist",
        "icon": "$(add)"
      }
    ],
    "keybindings": [
      {
        "command": "portfolioAnalyzer.searchStock",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "portfolioAnalyzer",
          "title": "StockLens",
          "icon": "$(graph-line)"
        }
      ]
    },
    "views": {
      "portfolioAnalyzer": [
        {
          "type": "webview",
          "id": "portfolioAnalyzer.dashboard",
          "name": "Dashboard"
        },
        {
          "type": "webview",
          "id": "portfolioAnalyzer.watchlist",
          "name": "Watchlist"
        }
      ]
    },
    "configuration": {
      "title": "StockLens",
      "properties": {
        "portfolioAnalyzer.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto-refresh prices during market hours"
        },
        "portfolioAnalyzer.refreshInterval": {
          "type": "number",
          "default": 60,
          "description": "Refresh interval in seconds"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "portfolioAnalyzer.refreshData",
          "when": "view == portfolioAnalyzer.dashboard",
          "group": "navigation"
        },
        {
          "command": "portfolioAnalyzer.showScoringInfo",
          "when": "view == portfolioAnalyzer.dashboard",
          "group": "navigation"
        },
        {
          "command": "portfolioAnalyzer.newWatchlist",
          "when": "view == portfolioAnalyzer.watchlist",
          "group": "navigation"
        },
        {
          "command": "portfolioAnalyzer.refreshWatchlist",
          "when": "view == portfolioAnalyzer.watchlist",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node -e \"const fs=require('fs'); fs.copyFileSync('src/indian_stocks.json', 'out/indian_stocks.json');\"",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
  }
}